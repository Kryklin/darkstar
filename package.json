{
  "name": "darkstar",
  "version": "3.0.4",
  "productName": "Darkstar",
  "description": "The Sovereign Post-Quantum Enclave for Identity & Asset Recovery.",
  "author": "Victor Kane",
  "license": "CC0-1.0",
  "private": true,
  "main": "dist/electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kryklin/darkstar.git"
  },
  "scripts": {
    "start": "node scripts/package.js",
    "build:rust": "cd d-asp/rust && cargo build --release",
    "build:go": "cd d-asp/go && go build -o main.exe main.go",
    "build:c": "cd d-asp/c && \"C:\\Program Files\\LLVM\\bin\\clang.exe\" -O3 -o dasp.exe main.c spna_engine.c gf_math.c ml_kem.c fips202.c sha512.c sha256.c aes.c rng.c poly.c poly_sampling.c -I. -lws2_32 -luserenv -ladvapi32 -lbcrypt -march=native -mtune=native -mavx2 -fno-strict-aliasing",
    "build:cuda": "cd d-asp/cuda && build_cuda.bat",
    "build:engines": "node scripts/build-engines.js",
    "build": "npm run build:engines && ng build --configuration production --base-href ./ && tsc --p tsconfig.electron.json && node scripts/build-integrity.js",
    "test:gen-kat": "python d-asp/scripts/gen_kat_vectors.py",
    "test:kat": "python d-asp/scripts/verify_kat.py",
    "test:interop": "python d-asp/scripts/verify_interop.py",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "lint:rust": "cd d-asp/rust && cargo clippy -- -D warnings",
    "lint:go": "cd d-asp/go && go vet ./...",
    "lint:c": "cd d-asp/c && \"C:\\Program Files\\LLVM\\bin\\clang.exe\" -fsyntax-only -Wall -Wextra -D_CRT_SECURE_NO_WARNINGS -D_CRT_NONSTDC_NO_DEPRECATE main.c spna_engine.c gf_math.c ml_kem.c fips202.c sha512.c sha256.c aes.c rng.c poly.c poly_sampling.c -I.",
    "lint:python": "npx pyright d-asp/python/dasp.py",
    "lint:ts": "npx tsc --noEmit",
    "lint:engines": "npm run lint:rust && npm run lint:go && npm run lint:c && npm run lint:python",
    "lint": "node scripts/lint.js",
    "format:ts": "npx prettier --write .",
    "format:rust": "cd d-asp/rust && cargo fmt",
    "format:go": "cd d-asp/go && gofmt -w .",
    "format:c": "cd d-asp/c && \"C:\\Program Files\\LLVM\\bin\\clang-format.exe\" -i *.c *.h",
    "format:python": "python -m pip install black && python -m black d-asp/python/dasp.py",
    "format": "node scripts/format.js",
    "audit": "node scripts/audit.js",
    "clean": "node scripts/clean.js",
    "checksums": "node scripts/checksums.js"
  },
  "prettier": {
    "printWidth": 200,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
