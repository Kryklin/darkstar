{
  "name": "@kryklin/darkstar-crypt-node",
  "version": "1.0.3",
  "description": "Standalone Node.js implementation of Darkstar Encryption",
  "main": "darkstar_crypt.js",
  "type": "module",
  "bin": {
    "darkstar-crypt": "darkstar_crypt.js"
  },
  "scripts": {
    "test": "node test.js",
    "build:go": "cd ../go && go build -o main.exe main.go",
    "build:rust": "cd ../rust && cargo build --release",
    "build": "npm run build:go && npm run build:rust",
    "test:kat": "python ../scripts/verify_kat.py",
    "test:interop": "python ../scripts/verify_interop.py"
  },
  "keywords": [
    "darkstar",
    "encryption",
    "cryptography",
    "aes",
    "cli"
  ],
  "author": "Victor Kane",
  "license": "CC0-1.0",
  "dependencies": {
    "@noble/post-quantum": "^0.5.4",
    "crystals-kyber": "^5.1.0"
  }
}
