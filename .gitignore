# =============================================================================
# DARKSTAR — Project-wide .gitignore
# Covers: Angular/Electron, Rust, Go, C, CUDA, Node.js, Python, C# (.NET), Zig
# =============================================================================

# -----------------------------------------------------------------------------
# Angular / TypeScript / Electron
# -----------------------------------------------------------------------------
/dist
/out
/out-tsc
/bazel-out
/.angular/cache
/coverage
/typings
/tmp

# Node
/node_modules
npm-debug.log
yarn-error.log

# Build output (compiled Electron main)
/electron/main.js
/electron/main.js.map

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# Visual Studio Code — keep shared workspace settings, ignore personal state
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains
*.iml
out/

# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates

# -----------------------------------------------------------------------------
# System files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# -----------------------------------------------------------------------------
# Secrets / local environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Rust engine  (rust)
# -----------------------------------------------------------------------------
rust/target/
# Keep Cargo.lock for binaries
# !rust/Cargo.lock

# -----------------------------------------------------------------------------
# Go engine  (go)
# -----------------------------------------------------------------------------
go/main
go/main.exe
go/d-asp.exe
go/d-asp_go.exe
go/dasp.exe

# -----------------------------------------------------------------------------
# C engine  (c)
# -----------------------------------------------------------------------------
c/d-spna-512
c/d-spna-512.exe
c/d-spna-512_asan.exe
c/d-spna-512_asan.pdb
# Compiled object files
c/*.obj
c/*.o
# MSVC / Clang linker artefacts
c/*.exp
c/*.lib
c/*.pdb
# Shared library output (rebuilt on demand)
c/d-spna-512_kem.dll
c/d-spna-512_kem.lib
c/d-spna-512_kem.exp
c/d-spna-512.lib
c/d-spna-512.exp
# Misc output files left by tooling
c/out.txt

# -----------------------------------------------------------------------------
# CUDA engine  (cuda)
# -----------------------------------------------------------------------------
cuda/d-spna-512_cuda.exe
cuda/d-spna-512_cuda.exp
cuda/d-spna-512_cuda.lib
cuda/d-spna-512_test.exe
cuda/d-spna-512_test.exp
cuda/d-spna-512_test.lib
cuda/*.obj
cuda/*.o
cuda/*.pdb

# -----------------------------------------------------------------------------
# Node.js engine  (node)
# -----------------------------------------------------------------------------
node/node_modules/
node/dist/
node/cipher.json
node/key.json
node/*.wasm
wasm/dasp_crypto.wasm

# -----------------------------------------------------------------------------
# Python engine  (python)
# -----------------------------------------------------------------------------
python/__pycache__/
python/*.pyc
python/*.pyo
python/.venv/
python/venv/
python/dist/
# Project root python scratch scripts
patch_cuda*.py
rename_docs.py
calc_checksum.py

# -----------------------------------------------------------------------------
# C# / .NET engine  (csharp)
# -----------------------------------------------------------------------------
csharp/bin/
csharp/obj/
# The DLL is built from c — do not commit the copy
csharp/dasp_kem.dll

# -----------------------------------------------------------------------------
# Zig engine  (zig)
# -----------------------------------------------------------------------------
zig/.zig-cache/
zig/zig-out/
zig/dist/

# -----------------------------------------------------------------------------
# Toolchain archives / downloaded binaries  (tools/)
# -----------------------------------------------------------------------------
tools/
*.zip
*.tar.gz
*.tar.xz
# dotnet install script (downloaded, not authored)
dotnet-install.ps1

# -----------------------------------------------------------------------------
# KAT / interop runtime artefacts
# -----------------------------------------------------------------------------
# Temp files written by test harnesses during runs
**/interop.json
**/interop_*.json
payload.txt
**/tmp_sk.hex
**/tmp_pk.hex
**/tmp_data.json
**/tmp_hwid.hex
# Benchmark log sessions (timestamped directories)
logs/
# Generated KAT & NIST artefacts — regenerated on demand
scripts/data/kat_vectors.json
scripts/data/master_keys.txt
scripts/data/nist_kat.rsp
scripts/data/crypto_analysis.json
scripts/log/
# Generated checksums (produced during release pipeline)
checksums.txt
# Adhoc test JSON files in root
cuda_test.json

# -----------------------------------------------------------------------------
# Mobile builds (Capacitor / iOS / Android)
# -----------------------------------------------------------------------------
/ios/App/build/
/ios/App/Pods/
/ios/App/DerivedData/
/android/.gradle/
/android/build/
/android/app/build/
/android/app/.cxx/
/android/captures/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
# Log files (project-wide)
*.log
# Plans directory (internal)
plans/
rust/target/
node/dist/
__pycache__/
 
# GitHub Releases Output
out-releases/
out-wrappers/
