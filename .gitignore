# =============================================================================
# DARKSTAR — Project-wide .gitignore
# Covers: Rust, C, CUDA, Node.js, Python (scripts)
# =============================================================================

# -----------------------------------------------------------------------------
# Node.js / TypeScript
# -----------------------------------------------------------------------------
/node_modules
npm-debug.log
yarn-error.log
/dist
/out
/tmp
/coverage
/typings
*.wasm
*.exe
*.dll

# -----------------------------------------------------------------------------
# IDEs and editors
# -----------------------------------------------------------------------------
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# System files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Secrets / local environment
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# Rust engine  (rust)
# -----------------------------------------------------------------------------
rust/target/

# Compiled object files
*.obj
*.o
# MSVC / Clang linker artefacts
*.exp
*.lib
*.pdb
# Shared library output (rebuilt on demand)
c/d-spna-512_kem.dll
c/d-spna-512_kem.lib
c/d-spna-512_kem.exp
c/d-spna-512.lib
c/d-spna-512.exp
# -----------------------------------------------------------------------------
# CUDA engine  (cuda)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Python / Scripts  (python)
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.py
.venv/
venv/

# -----------------------------------------------------------------------------
# KAT / interop runtime artefacts
# -----------------------------------------------------------------------------
# Temp files written by test harnesses during runs
**/interop.json
**/interop_*.json
payload.txt
**/tmp_sk.hex
**/tmp_pk.hex
**/tmp_data.json
**/tmp_hwid.hex
# Benchmark log sessions (timestamped directories)
logs/
# Generated KAT & NIST artefacts — regenerated on demand
scripts/data/kat_vectors.json
scripts/data/master_keys.txt
scripts/data/nist_kat.rsp
scripts/data/crypto_analysis.json
scripts/log/
# Generated checksums (produced during release pipeline)
checksums.txt
cuda_test.json

# Miscellaneous
*.log
out-releases/
out-wrappers/
tools/

# Ignored output files
*.txt
!scripts/data/*.txt
*.lib
*.exp
*.o
*.obj
*.pdb
*.ilk
c/test_checksum.c
rust/test_c.rs
scratch/
